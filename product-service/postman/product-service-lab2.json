{
  "info": {
    "name": "product-service-lab2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET all products",
      "request": { "method": "GET", "url": "http://localhost:8080/api/v1/products" }
    },
    {
      "name": "GET product by ID",
      "request": { "method": "GET", "url": "http://localhost:8080/api/v1/products/1" }
    },
    {
      "name": "GET product not found",
      "request": { "method": "GET", "url": "http://localhost:8080/api/v1/products/9999" }
    },
    {
      "name": "POST create product",
      "request": {
        "method": "POST",
        "url": "http://localhost:8080/api/v1/products",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"name\":\"Webcam\",\"price\":99.99,\"stockQty\":20,\"category\":\"Peripherals\"}" }
      }
    },
    {
      "name": "POST validation error",
      "request": {
        "method": "POST",
        "url": "http://localhost:8080/api/v1/products",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"name\":\"\",\"price\":-5,\"stockQty\":0,\"category\":\"\"}" }
      }
    },
    {
      "name": "PUT update product",
      "request": {
        "method": "PUT",
        "url": "http://localhost:8080/api/v1/products/1",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"name\":\"Pro Laptop\",\"price\":1299.0,\"stockQty\":5,\"category\":\"Electronics\"}" }
      }
    },
    {
      "name": "DELETE product",
      "request": { "method": "DELETE", "url": "http://localhost:8080/api/v1/products/1" }
    },
    {
      "name": "DELETE product not found",
      "request": { "method": "DELETE", "url": "http://localhost:8080/api/v1/products/9999" }
    }
  ]
}